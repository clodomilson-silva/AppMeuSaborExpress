{
  "name": "meusabor-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions — AppMeuSabor (pagamentos, pedidos, webhooks)",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
